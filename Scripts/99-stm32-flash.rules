# 99-stm32-flash.rules — non-root USB access for flashing the STM32H743.
#
# Without these rules, st-flash / dfu-util / STM32CubeProgrammer fail with
# "permission denied" or "libusb open failed" unless run as root. The rules grant
# the logged-in user access via systemd's "uaccess" tag (no group needed on
# modern distros). UART flashing uses a serial port instead — that needs group
# membership, not a udev rule (see Scripts/README.md → Linux USB permissions).
#
# Install:
#   sudo cp Scripts/99-stm32-flash.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules && sudo udevadm trigger
#   # then unplug and replug the probe / board
#
# (The stlink package usually installs its own ST-Link rules; this file also
# covers the STM32 DFU bootloader, which those don't.)

# --- ST-Link debug probes (SWD) ---
SUBSYSTEM=="usb", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="3744", MODE="0660", TAG+="uaccess"  # ST-Link/V1
SUBSYSTEM=="usb", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="3748", MODE="0660", TAG+="uaccess"  # ST-Link/V2
SUBSYSTEM=="usb", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="374b", MODE="0660", TAG+="uaccess"  # ST-Link/V2-1
SUBSYSTEM=="usb", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="374d", MODE="0660", TAG+="uaccess"  # ST-Link/V3 (DFU)
SUBSYSTEM=="usb", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="374e", MODE="0660", TAG+="uaccess"  # ST-Link/V3
SUBSYSTEM=="usb", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="374f", MODE="0660", TAG+="uaccess"  # ST-Link/V3
SUBSYSTEM=="usb", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="3753", MODE="0660", TAG+="uaccess"  # ST-Link/V3
SUBSYSTEM=="usb", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="3754", MODE="0660", TAG+="uaccess"  # ST-Link/V3

# --- STM32 ROM USB DFU bootloader (BOOT0 high) ---
SUBSYSTEM=="usb", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="df11", MODE="0660", TAG+="uaccess"  # STM32 DFU
